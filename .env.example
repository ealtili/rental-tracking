# Rental Tracking App Environment Configuration Template
# COPY THIS FILE TO .env AND GENERATE YOUR OWN UNIQUE SECRETS FOR PRODUCTION!

# 64-character hexadecimal key for AES-256-GCM Database Encryption
DB_ENCRYPTION_KEY=6a3c8f8b8a928ef23214b7e8d9c2e4a8b8f8a92b2345e67d8a92b2345e67d8f9

# 32-character key for SMTP Password Encryption (AES-256-CBC)
SMTP_ENCRYPTION_KEY=a3c8f8b8a928ef23214b7e8d9c2e4a8b

# 16-character Initialization Vector for SMTP password encryption
SMTP_ENCRYPTION_IV=f7e8a92b2345e67d

# Express Server Port
