# Rental Tracking App Environment Configuration Template
# COPY THIS FILE TO .env AND GENERATE YOUR OWN UNIQUE SECRETS FOR PRODUCTION!

# 64-character hexadecimal key for AES-256-GCM Database Encryption
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=insert_64_character_hex_database_key_here

# 32-character key for SMTP Password Encryption (AES-256-CBC)
# Generate using: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SMTP_ENCRYPTION_KEY=insert_32_character_smtp_pass_key_here

# 16-character Initialization Vector for SMTP password encryption
# Generate using: node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
SMTP_ENCRYPTION_IV=insert_16_character_initialization_iv_here

# Express Server Port
PORT=5000
